# ─────────────────────────────────────────────────────
# 페이쌤 CX 모니터링 시스템 - 환경변수 설정
# 이 파일을 복사해서 .env 파일로 만들고 실제 값을 입력하세요
# cp .env.example .env
# ─────────────────────────────────────────────────────

# ── 슬랙 설정 ──────────────────────────────────────
# Slack Bot Token (xoxb- 로 시작)
# 발급 방법: https://api.slack.com/apps → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=xoxb-여기에-슬랙봇-토큰을-입력하세요

# 알림 받을 슬랙 채널 ID
# 채널 ID 확인: 채널 우클릭 → 채널 세부정보 복사 → 맨 아래 채널 ID
# 예시: C08XXXXXXXXX
SLACK_CHANNEL_ID=여기에-채널-ID를-입력하세요

# ── 채널톡 설정 ────────────────────────────────────
# 채널톡 API Access Key (채널톡 개발자 포털에서 발급)
CHANNELTALK_ACCESS_KEY=여기에-채널톡-ACCESS-KEY를-입력하세요

# 채널톡 API Access Secret
CHANNELTALK_ACCESS_SECRET=여기에-채널톡-ACCESS-SECRET을-입력하세요

# 채널톡 Webhook Token (Webhook 등록 시 발급됨, 선택사항)
# CHANNELTALK_WEBHOOK_TOKEN=여기에-Webhook-Token을-입력하세요

# ── 서버 설정 ──────────────────────────────────────
# 서버 포트 (기본값: 3000)
PORT=3000

# 실행 환경 (development | production)
NODE_ENV=development
